# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Environment / secrets
.env
.env.*
!.env.example

# IDEs
.idea/
# Xcode user state (any depth)
*.xcuserstate
**/xcuserdata/
xcuserdata/
*.swp
*~

# Xcode — build products & intermediates (keep source; Pods/ is tracked in this repo)
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.app
*.xcarchive
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Local DerivedData override used for CLI builds
.derivedDataIOS/

# Swift Package Manager — local build tree (`swift build`, Xcode SPM)
.build/
**/.build/
.swiftpm/configuration/registries.json
.swiftpm/xcode/xcuserdata/
.netrc

# Test & CI artifacts
*.xcresult
*.xcresult/
timeline.xctimeline
playground.xcworkspace

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output
fastlane/readme.md

# Carthage (if used later)
Carthage/Build/

# Accio (if used)
Dependencies/
.accio/

